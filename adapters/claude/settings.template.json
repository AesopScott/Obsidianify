            "type": "command",
            "command": "\"PYTHON\" \"OMI_SCRIPT\" refresh-global --config \"OBSIDIANIFY_CONFIG\" --agent \"claude\" --emit-hook-context"
          }
        ]
      }
    ]
  }
}
